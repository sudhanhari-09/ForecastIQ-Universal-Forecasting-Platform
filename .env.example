# ForecastIQ Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Secret key used for session signing, CSRF tokens, and encrypting AI API keys.
# Generate a strong random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Database connection URL.
# Default: SQLite (stored in instance/forecastiq.db)
# For PostgreSQL:
#   DATABASE_URL=postgresql://user:password@host:5432/forecastiq
DATABASE_URL=
